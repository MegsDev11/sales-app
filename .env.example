NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key
# One-time admin bootstrap (POST /api/admin/bootstrap), then remove ADMIN_PASSWORD
ADMIN_EMAIL=manager@yourcompany.co.za
ADMIN_PASSWORD=change-me-after-bootstrap
ADMIN_NAME=Sales Manager
# Optional — only needed for npm run db:migrate
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
