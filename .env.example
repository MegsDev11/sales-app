NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key
# One-time owner bootstrap (POST /api/admin/bootstrap), then remove OWNER_PASSWORD
OWNER_EMAIL=owner@yourcompany.co.za
OWNER_PASSWORD=change-me-after-bootstrap
OWNER_NAME=Megs Owner
# Legacy admin bootstrap vars (optional fallback)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
# Optional — only needed for npm run db:migrate
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Optional — Ruijie / Reyee Cloud (apply via service_rj@ruijienetworks.com)
RUIJIE_APP_ID=
RUIJIE_APP_SECRET=
# RUIJIE_CLOUD_BASE_URL=https://cloud.ruijienetworks.com
